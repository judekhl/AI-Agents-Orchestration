# ── Copy this file to .env and fill in real values ───────────────────────────
# NEVER commit .env — it is listed in .gitignore

# ── HuggingFace (optional — only needed for gated models) ───────────────────
# Get your token at https://huggingface.co/settings/tokens
# Leave empty or omit if using a public, no-auth model (recommended for assignment)
HF_TOKEN=

# ── Primary model ────────────────────────────────────────────────────────────
# Set to the HuggingFace model ID or local path
# Example public models (no token needed):
#   facebook/opt-6.7b       — 6.7B params, public
#   EleutherAI/gpt-j-6b     — 6B params, public
#   TheBloke/Llama-2-7B-GGUF — GGUF variant, public
MODEL_ID=facebook/opt-6.7b

# ── Cache and shard directories ───────────────────────────────────────────────
# Where Hugging Face downloads model files
MODEL_CACHE_DIR=./models

# Where AirLLM stores pre-split layer shards
AIRLLM_SHARD_DIR=./airllm_shards

# Where AirLLM stores its runtime cache
AIRLLM_CACHE_DIR=./airllm_cache

# ── Experiment configuration ─────────────────────────────────────────────────
# Device to use: cpu | cuda | mps
# For CPU-only machines, leave as "cpu"
DEVICE=cpu

# Maximum new tokens to generate per inference call
MAX_NEW_TOKENS=200

# Number of repetitions for stability experiments
N_RUNS=3

# ── Output directories ────────────────────────────────────────────────────────
RESULTS_RAW_DIR=./results/raw
RESULTS_PROCESSED_DIR=./results/processed
FIGURES_DIR=./figures

# ── Economic analysis assumptions ─────────────────────────────────────────────
# Hardware purchase price (USD) — your machine or estimated cost
HARDWARE_COST_USD=800

# Hardware amortization period in years
AMORTIZATION_YEARS=3

# Local electricity rate (USD per kWh) — use your region's rate
ELECTRICITY_RATE_USD_PER_KWH=0.12

# Estimated CPU TDP in watts (check your CPU spec sheet)
CPU_TDP_WATTS=45

# API pricing reference (update to current prices when you run the analysis)
# Claude claude-sonnet-4-6: $3.00 per 1M input tokens, $15.00 per 1M output tokens (as of 2026-06)
# GPT-4o: $2.50 per 1M input tokens, $10.00 per 1M output tokens (as of 2026-06)
API_INPUT_PRICE_PER_1M_TOKENS=3.00
API_OUTPUT_PRICE_PER_1M_TOKENS=15.00
API_PRICING_DATE=2026-06-23
API_PRICING_MODEL=claude-sonnet-4-6
