# ── Copy this file to .env and fill in real values ───────────────────────────
# NEVER commit .env — it is listed in .gitignore

# ════════════════════════════════════════════════════════════════════════════
# IMPORTANT — OneDrive / repo users:
#   This repository lives inside OneDrive. Model weights, HuggingFace cache,
#   AirLLM shards, and GGUF files must NOT be stored inside the repo folder
#   or anywhere under OneDrive. Reasons:
#     1. Git will not track them (they are gitignored) but OneDrive WILL sync
#        them, wasting bandwidth and cloud storage for multi-GB weight files.
#     2. AirLLM shard writes during inference may conflict with OneDrive's
#        background sync process, causing file-lock errors.
#   Recommended layout:
#     C:\ai-model-cache\hf           ← HuggingFace model downloads
#     C:\ai-model-cache\airllm-cache ← AirLLM runtime cache
#     C:\ai-model-cache\airllm-shards← AirLLM per-layer shard files
#     C:\ai-model-cache\gguf         ← GGUF single-file downloads
#   Create these folders once before downloading any model:
#     mkdir C:\ai-model-cache\hf
#     mkdir C:\ai-model-cache\airllm-cache
#     mkdir C:\ai-model-cache\airllm-shards
#     mkdir C:\ai-model-cache\gguf
# ════════════════════════════════════════════════════════════════════════════

# ── HuggingFace token (optional — only needed for gated models) ──────────────
# All three models selected for this assignment are public (no token needed).
# Leave this empty.
HF_TOKEN=

# ── Model IDs (do not change unless switching models) ────────────────────────
MODEL_ID_WARMUP=Qwen/Qwen2.5-0.5B-Instruct
MODEL_ID_STRESS=facebook/opt-6.7b
MODEL_ID_FALLBACK_GGUF=bartowski/Qwen2.5-7B-Instruct-GGUF
FALLBACK_GGUF_QUANT=Q4_K_M

# ── Cache directories — MUST be outside the repo and outside OneDrive ────────
# HuggingFace model download cache (transformers models)
HF_HOME=C:\ai-model-cache\hf
MODEL_CACHE_DIR=C:\ai-model-cache\hf

# AirLLM per-layer shard storage (large — ~13 GB for OPT-6.7B)
AIRLLM_SHARD_DIR=C:\ai-model-cache\airllm-shards

# AirLLM runtime cache
AIRLLM_CACHE_DIR=C:\ai-model-cache\airllm-cache

# GGUF single-file storage
GGUF_DIR=C:\ai-model-cache\gguf

# ── Experiment configuration ─────────────────────────────────────────────────
# Device: cpu | cuda | mps  (this machine has no CUDA GPU — use cpu)
DEVICE=cpu

# Tokens to generate per inference call
MAX_NEW_TOKENS=200

# Repetitions for stability extension
N_RUNS=3

# CPU TDP in watts (i5-1135G7 rated at 28W base / 35W boost — use 35 for inference)
CPU_TDP_WATTS=35

# ── Output directories (stay inside repo — these are small JSON/CSV/PNG) ─────
RESULTS_RAW_DIR=./results/raw
RESULTS_PROCESSED_DIR=./results/processed
FIGURES_DIR=./figures

# ── Economic analysis assumptions ─────────────────────────────────────────────
# Laptop purchase price estimate (USD)
HARDWARE_COST_USD=800

# Amortization period in years
AMORTIZATION_YEARS=3

# Electricity rate — use your local rate (USD per kWh)
ELECTRICITY_RATE_USD_PER_KWH=0.12

# API pricing reference (verify current prices before final analysis)
# claude-sonnet-4-6: $3.00/1M input, $15.00/1M output (as of 2026-06-23)
API_INPUT_PRICE_PER_1M_TOKENS=3.00
API_OUTPUT_PRICE_PER_1M_TOKENS=15.00
API_PRICING_DATE=2026-06-23
API_PRICING_MODEL=claude-sonnet-4-6
