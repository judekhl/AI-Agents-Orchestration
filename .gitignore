# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
.env/
ENV/

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Environment variables (NEVER commit real secrets) ────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Model weights and large binary files ────────────────────────────────────
# PyTorch
*.bin
*.pt
*.pth
# Safetensors (HuggingFace standard)
*.safetensors
# GGUF / GGML (llama.cpp)
*.gguf
*.ggml
# ONNX
*.onnx
# Other large model formats
*.npz
*.npy

# ── Model and cache directories ──────────────────────────────────────────────
models/
model_cache/
model_weights/
# HuggingFace Hub cache
.cache/
hf_cache/
hub/
huggingface/
# AirLLM shard and cache directories
airllm_cache/
airllm_shards/
shards/
layer_shards/
# Transformers offload folder
offload/

# ── Large temporary outputs ──────────────────────────────────────────────────
*.tmp
*.log
tmp/
temp/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS-specific files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── IDE files ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ── Testing and coverage ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── What IS committed from results/ ──────────────────────────────────────────
# results/raw/*.json        → committed (small metric files)
# results/processed/*.csv   → committed (generated summaries)
# figures/*.png             → committed (generated graphs)
# figures/screenshots/*.png → committed (captured screenshots)
# The .gitkeep files below ensure empty dirs are tracked until real files land.
